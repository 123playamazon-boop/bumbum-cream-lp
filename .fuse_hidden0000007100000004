    var state = document.getElementById('gstate');
    var total = rows.length;
    function update(){
      var n = 0;
      rows.forEach(function(r){ if(r.classList.contains('on')) n++; });
      var pct = total ? Math.round((n/total)*100) : 0;
      needle.style.left = pct + '%';
      var label;
      if(n===0) label = 'Awaiting Assessment';
      else if(pct<34) label = 'Mostly Firm';
      else if(pct<67) label = 'Some Laxity';
      else if(pct<100) label = 'Noticeable Laxity';
      else label = 'Advanced Laxity';
      state.textContent = label;
    }
    rows.forEach(function(r){
      r.addEventListener('click', function(){
        r.classList.toggle('on');
        update();
      });
    });
  })();
</script>

